// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MaterialType {
  NOTE
  LINK
  FILE
}

enum StudyGroupRole {
  OWNER
  EDITOR
  MEMBER
}

model User {
  id           String  @id @default(uuid()) @db.Uuid
  name         String
  email        String  @unique
  passwordHash String  @map("password_hash")
  avatarUrl    String? @map("avatar_url")

  personalSubjects PersonalSubject[]

  ownedStudyGroups      StudyGroup[]       @relation("StudyGroupOwner")
  studyGroupMemberships StudyGroupMember[]

  createdStudyGroupTopics    StudyGroupTopic[]    @relation("StudyGroupTopicCreator")
  createdStudyGroupMaterials StudyGroupMaterial[] @relation("StudyGroupMaterialCreator")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model PersonalSubject {
  id          String  @id @default(uuid()) @db.Uuid
  ownerId     String  @map("owner_id") @db.Uuid
  name        String
  description String?
  color       String?

  owner     User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  materials PersonalMaterial[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ownerId])
  @@map("personal_subjects")
}

model PersonalMaterial {
  id        String       @id @default(uuid()) @db.Uuid
  subjectId String       @map("subject_id") @db.Uuid
  type      MaterialType
  title     String
  content   String?
  url       String?

  fileName    String? @map("file_name")
  storagePath String? @map("storage_path")
  mimeType    String? @map("mime_type")
  fileSize    Int?    @map("file_size")

  subject PersonalSubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([subjectId])
  @@index([type])
  @@map("personal_materials")
}

model StudyGroup {
  id          String  @id @default(uuid()) @db.Uuid
  ownerId     String  @map("owner_id") @db.Uuid
  name        String
  description String?
  inviteCode  String  @unique @map("invite_code") @db.VarChar(12)

  owner   User               @relation("StudyGroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members StudyGroupMember[]
  topics  StudyGroupTopic[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ownerId])
  @@map("study_groups")
}

model StudyGroupMember {
  id      String         @id @default(uuid()) @db.Uuid
  groupId String         @map("group_id") @db.Uuid
  userId  String         @map("user_id") @db.Uuid
  role    StudyGroupRole @default(MEMBER)

  group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now()) @map("joined_at")

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId, role])
  @@map("study_group_members")
}

model StudyGroupTopic {
  id          String  @id @default(uuid()) @db.Uuid
  groupId     String  @map("group_id") @db.Uuid
  createdById String? @map("created_by_id") @db.Uuid
  name        String
  description String?
  color       String?
  position    Int     @default(0)

  group     StudyGroup           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User?                @relation("StudyGroupTopicCreator", fields: [createdById], references: [id], onDelete: SetNull)
  materials StudyGroupMaterial[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([groupId, position])
  @@index([createdById])
  @@map("study_group_topics")
}

model StudyGroupMaterial {
  id          String       @id @default(uuid()) @db.Uuid
  topicId     String       @map("topic_id") @db.Uuid
  createdById String?      @map("created_by_id") @db.Uuid
  type        MaterialType
  title       String
  content     String?
  url         String?

  fileName    String? @map("file_name")
  storagePath String? @map("storage_path")
  mimeType    String? @map("mime_type")
  fileSize    Int?    @map("file_size")

  topic     StudyGroupTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("StudyGroupMaterialCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([topicId, createdAt])
  @@index([createdById])
  @@index([type])
  @@map("study_group_materials")
}
